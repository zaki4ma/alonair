{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "GOOGLE_SERVICE_INFO_PLIST": "$GOOGLE_SERVICE_INFO_PLIST"
      },
      "prebuildCommand": "node -e \"const fs=require('fs');fs.writeFileSync('./GoogleService-Info.plist',Buffer.from(process.env.GOOGLE_SERVICE_INFO_PLIST,'base64').toString())\""
    }
  },
  "submit": {
    "production": {}
  }
}
