{
  "expo": {
    "name": "alonair",
    "slug": "alonair",
    "scheme": "alonair",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3346A0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alonair.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "作業環境を撮影してAIがDNAを解析します。",
        "NSPhotoLibraryUsageDescription": "フォトライブラリから作業環境の写真を選択できます。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3346A0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ]
  }
}
